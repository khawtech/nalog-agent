# ──────────────────────────────────────────────────────────────────────────
# NaLog Agent — environment configuration
# Copy to .env and fill in. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ── Alibaba Cloud Model Studio (DashScope) — Qwen models ────────────────────
# Get a key: https://bailian.console.alibabacloud.com/#/api_key
# International (Singapore) endpoint. For Beijing use https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-replace-me
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model tiering (cost-aware: cheap router, mid chat, strong reasoning)
MODEL_ROUTER=qwen-turbo
MODEL_CHAT=qwen-plus
MODEL_REASON=qwen-max
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# Token budget guardrail (per conversation turn). 0 = disabled.
MAX_TOKENS_PER_TURN=6000

# ── Memory storage driver: "local" (file) or "alibaba" (Tablestore) ─────────
STORAGE_DRIVER=local
DATA_DIR=./data

# Alibaba Cloud Tablestore (only when STORAGE_DRIVER=alibaba)
# https://otsnext.console.aliyun.com/  — deploy in Thailand (Bangkok) ap-southeast-7.
TABLESTORE_ENDPOINT=https://nalog-agent.ap-southeast-7.ots.aliyuncs.com
TABLESTORE_INSTANCE=nalog-agent
TABLESTORE_ACCESS_KEY_ID=
TABLESTORE_ACCESS_KEY_SECRET=

# ── Vector store driver: "local" (in-process cosine) or "dashvector" ────────
VECTOR_DRIVER=local

# Alibaba Cloud DashVector (only when VECTOR_DRIVER=dashvector)
# https://dashvector.console.aliyun.com/
# Note: DashVector is NOT available in Thailand (ap-southeast-7). Create the cluster
# in Singapore (ap-southeast-1); FC reaches it cross-region over HTTPS. The endpoint
# is the cluster-specific host shown in the DashVector console.
DASHVECTOR_ENDPOINT=
DASHVECTOR_API_KEY=
DASHVECTOR_COLLECTION=nalog_memory

# ── NaLog platform (read-only data connector) ──────────────────────────────
# Live API base from the NaLog deployment.
NALOG_API_URL=https://je44m5betsgtn2575co36e3cii0qjata.lambda-url.ap-southeast-2.on.aws
# Firebase ID token (Bearer). In NaLog dev mode any non-empty value works.
NALOG_AUTH_TOKEN=Bearer dummy
# Set true to use built-in demo data instead of calling the live NaLog API.
NALOG_USE_DEMO=false

# Comma-separated browser origins allowed to call the agent API (CORS).
ALLOWED_ORIGINS=https://nalog-app.khawtech.com,http://localhost:5173

# ── ChirpStack (LoRaWAN downlink for approved irrigation actions) ───────────
CHIRPSTACK_API_URL=
CHIRPSTACK_API_TOKEN=
# Safety: require human approval before any pump downlink is sent.
REQUIRE_HUMAN_APPROVAL=true

# Shared-secret gate for mutating endpoints (chat, proposal approve/reject).
# Clients must send as `x-api-key` or `Authorization: Bearer <key>`.
AGENT_API_KEY=
